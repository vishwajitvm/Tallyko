# --- FREE CLOUD DEPLOYMENT VARIABLES ---
# Copy these into your Render "Environment Variables" settings
# DO NOT COMMIT THIS FILE WITH REAL PASSWORDS

ENVIRONMENT=production
JWT_SECRET=replace_me_with_a_secure_long_random_string

# 1. Neon.tech Postgres URL
# Make sure to include +asyncpg if you are copying a raw postgresql:// link
DATABASE_URL=postgresql+asyncpg://user:password@ep-cool-db.neon.tech/neondb

# 2. Upstash Redis URL
REDIS_URL=redis://default:password@eu2-cool-redis.upstash.io:30000

# 3. Cloudflare R2 / AWS S3 Credentials
MINIO_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=your_r2_access_key
MINIO_SECRET_KEY=your_r2_secret_key
